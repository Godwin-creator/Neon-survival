rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scores
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user ID of the player
    //   - displayName: string (required, max 50 chars) - The display name of the player
    //   - score: number (required, >= 0) - The score achieved
    //   - wave: number (required, >= 1) - The wave reached
    //   - createdAt: timestamp (required) - When the score was achieved
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The user ID of the player
    //   - playerColor: string (required)
    //   - particleStyle: string (required)
    //   - bgTheme: string (required)
    //   - volume: number (required)
    //   - particlesEnabled: boolean (required)
    //   - shakeEnabled: boolean (required)
    //   - accessibilityMode: boolean (required)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidScore(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'score', 'wave', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.wave is number && data.wave >= 1 &&
             data.createdAt is timestamp;
    }

    function isValidUserPreferences(data) {
      return hasOnlyAllowedFields(['uid', 'playerColor', 'particleStyle', 'bgTheme', 'volume', 'particlesEnabled', 'shakeEnabled', 'accessibilityMode', 'updatedAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             data.playerColor is string && data.playerColor.size() > 0 && data.playerColor.size() <= 20 &&
             data.particleStyle is string && data.particleStyle.size() > 0 && data.particleStyle.size() <= 20 &&
             data.bgTheme is string && data.bgTheme.size() > 0 && data.bgTheme.size() <= 20 &&
             data.volume is number && data.volume >= 0 && data.volume <= 1 &&
             data.particlesEnabled is bool &&
             data.shakeEnabled is bool &&
             data.accessibilityMode is bool &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /scores/{scoreId} {
      // Anyone can read the leaderboard
      allow read: if true;
      
      // Only authenticated users can create a score, and they must set their own uid
      allow create: if isAuthenticated() && 
                    isValidScore(request.resource.data) && 
                    request.resource.data.uid == request.auth.uid;
                    
      // Scores cannot be updated or deleted once created (immutable leaderboard)
      allow update, delete: if false;
    }

    match /users/{userId} {
      // Users can only read and write their own preferences
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      allow create: if isAuthenticated() && 
                    request.auth.uid == userId &&
                    isValidUserPreferences(request.resource.data) &&
                    request.resource.data.uid == userId;
                    
      allow update: if isAuthenticated() && 
                    request.auth.uid == userId &&
                    isValidUserPreferences(request.resource.data) &&
                    request.resource.data.uid == userId &&
                    uidUnchanged();
                    
      allow delete: if false;
    }
  }
}
