rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scores
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user ID of the player
    //   - displayName: string (required, max 50 chars) - The display name of the player
    //   - score: number (required, >= 0) - The score achieved
    //   - wave: number (required, >= 1) - The wave reached
    //   - createdAt: timestamp (required) - When the score was achieved
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidScore(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'score', 'wave', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.wave is number && data.wave >= 1 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /scores/{scoreId} {
      // Anyone can read the leaderboard
      allow read: if true;
      
      // Only authenticated users can create a score, and they must set their own uid
      allow create: if isAuthenticated() && 
                    isValidScore(request.resource.data) && 
                    request.resource.data.uid == request.auth.uid;
                    
      // Scores cannot be updated or deleted once created (immutable leaderboard)
      allow update, delete: if false;
    }
  }
}
